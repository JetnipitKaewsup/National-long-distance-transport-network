# Simulation parameters
SIM_DURATION=3600
TIME_STEP=0.1
RANDOM_SEED=42

# Network topology
NUM_CORE_NODES=5
NUM_SATELLITES=4
NUM_DRONES=8
NUM_VEHICLES=5
NUM_BASES=5

# 5G/6G Parameters
CORE_BANDWIDTH_5G=10240
CORE_BANDWIDTH_6G=102400
CORE_LATENCY_5G=1
CORE_LATENCY_6G=0.1
CORE_RELIABILITY_5G=0.999
CORE_RELIABILITY_6G=0.9999

# Satellite Parameters
SAT_BANDWIDTH=100
SAT_LATENCY=250
SAT_RELIABILITY=0.95

# Drone Parameters
DRONE_BANDWIDTH=50
DRONE_LATENCY=10
DRONE_RELIABILITY=0.9
DRONE_BATTERY_CAPACITY=3600
DRONE_CHARGE_RATE=600
DRONE_MAX_SPEED=15
DRONE_MAX_RANGE=1000
DRONE_MESH_RANGE=300
DRONE_DISCHARGE_PATROL=60
DRONE_DISCHARGE_MESH=90
ENABLE_HOT_SWAP=true
ENABLE_AUTO_CHARGING=true

# Handover Parameters
HANDOVER_LATENCY_5G_TO_SAT=500
HANDOVER_LATENCY_5G_TO_DRONE=100
HANDOVER_LATENCY_SAT_TO_DRONE=200

# Feature flags
ENABLE_DIGITAL_TWIN=true
ENABLE_ENCRYPTION=true
ENABLE_REASONING=true
REAL_TIME_PLOT=false
COLLECT_METRICS=true

# Output
OUTPUT_DIR=./simulation_output
SAVE_INTERVAL=60
LOG_LEVEL=INFO